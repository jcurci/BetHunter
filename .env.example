# Copie para `.env` nesta pasta OU use `../.env` na raiz do monorepo.
# O app.config.ts carrega ambos (esta pasta tem prioridade sobre a raiz).

EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:3000
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# O URL scheme iOS (REVERSED_CLIENT_ID) é derivado automaticamente deste valor.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Client ID Android (credencial OAuth tipo "Android" na Google Cloud, package + SHA-1).
# Usado como webClientId no Android; no iOS não é usado.
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
